# ============================================================
# 应有成本估算 AI 助手 — 环境变量配置模板
# 复制本文件为 .env，填入你的真实 API Key 后启动服务
# ============================================================

# -----------------------------------------------------------
# DeepSeek 对话 API（必填）
# 用于半相关问题的兜底生成回答
# 注册: https://platform.deepseek.com
# -----------------------------------------------------------
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# -----------------------------------------------------------
# Embedding 语义检索配置（推荐启用）
#
# 两种模式可选：
#   local = 本地字符串匹配（零网络依赖，但不理解语义）
#   api   = 调用 Embedding API（推荐，能理解换说法的提问）
# -----------------------------------------------------------
EMBEDDING_MODE=api

# Embedding API 配置（EMBEDDING_MODE=api 时必填）
# 支持任何 OpenAI API 兼容的服务：
#   - SiliconFlow:  https://api.siliconflow.cn/v1
#   - OpenAI:       https://api.openai.com/v1
#   - Azure OpenAI: https://xxx.openai.azure.com/openai/deployments/xxx
#
# SiliconFlow 注册: https://cloud.siliconflow.cn
EMBEDDING_API_KEY=sk-your-embedding-api-key-here
EMBEDDING_API_URL=https://api.siliconflow.cn/v1
EMBEDDING_API_MODEL=BAAI/bge-large-zh-v1.5

# -----------------------------------------------------------
# ChromaDB 向量数据库（默认即可）
# -----------------------------------------------------------
CHROMA_PERSIST_DIR=./chroma_db

# -----------------------------------------------------------
# FAQ 匹配阈值（可根据效果调整）
#
# HIGH: 高于此值直接返回答案（不调用 LLM）
# LOW:  低于此值直接拒绝回答（防止幻觉）
# 范围: 0.0 ~ 1.0
# -----------------------------------------------------------
FAQ_THRESHOLD_HIGH=0.75
FAQ_THRESHOLD_LOW=0.40
FAQ_TOP_K=3

# -----------------------------------------------------------
# 第三阶段：检索优化开关
# -----------------------------------------------------------
ENABLE_RERANK=true
ENABLE_HYBRID_SEARCH=true
ENABLE_QUERY_REWRITE=false
ENABLE_LLM_CONTEXT_COMPRESS=false

# 重排序权重（三项之和必须等于 1.0）
RERANK_VECTOR_WEIGHT=0.6
RERANK_KEYWORD_WEIGHT=0.3
RERANK_LENGTH_WEIGHT=0.1

# 上下文压缩参数
CONTEXT_SIMILARITY_THRESHOLD=0.35
CONTEXT_MAX_CHUNK_LENGTH=600
